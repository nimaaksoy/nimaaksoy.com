{
  "manifest_version": 3,
  "name": "Life in Dots",
  "version": "1.0.0",
  "description": "A thoughtful new tab replacement to visualize the days you have lived and the possible time still ahead.",
  "permissions": ["storage"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "offline_enabled": true
}
